<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a1628"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HiCardi ECG 부정맥 분석기"
            android:textColor="#00cfff"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/fileNameText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="파일을 선택하세요"
            android:textColor="#ffffff"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/openButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="JSON 열기" />

            <Button
                android:id="@+id/playButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:enabled="false"
                android:text="▶ 재생" />

            <Button
                android:id="@+id/resetButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:enabled="false"
                android:text="처음" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="속도"
                android:textColor="#5a7a9a" />

            <SeekBar
                android:id="@+id/speedSeek"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/speedText"
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="1.0 beat/s"
                android:textColor="#ffffff" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/hrText"
                android:layout_width="0dp"
                android:layout_height="84dp"
                android:layout_weight="1"
                android:background="#132040"
                android:gravity="center"
                android:text="— bpm"
                android:textColor="#ffffff"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rhythmText"
                android:layout_width="0dp"
                android:layout_height="84dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="#132040"
                android:gravity="center"
                android:padding="8dp"
                android:text="리듬 계산 대기"
                android:textColor="#00ff88"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/beatText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Beat: 0 / 0"
            android:textColor="#5a7a9a"
            android:textSize="13sp" />

        <com.example.hicardimonitor.EcgView
            android:id="@+id/ecgView"
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:layout_marginTop="6dp"
            android:background="#0a1628" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="실제 라벨(JSON)"
            android:textColor="#00cfff"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/labelText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="#132040"
            android:padding="14dp"
            android:text="—"
            android:textColor="#00ff88"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/descText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#132040"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingBottom="14dp"
            android:text="JSON 파일을 열고 재생하세요"
            android:textColor="#ffffff"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🤖 AI 부정맥 분류"
                android:textColor="#00cfff"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/aiStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="모델 로딩 중..."
                android:textColor="#5a7a9a"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/alertText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="#3a0a0a"
            android:padding="12dp"
            android:text=""
            android:textColor="#ef5350"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/predClassText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="#132040"
            android:paddingStart="14dp"
            android:paddingTop="14dp"
            android:paddingEnd="14dp"
            android:text="—"
            android:textColor="#00ff88"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/predDescText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#132040"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingBottom="14dp"
            android:text="모델이 준비되면 비트마다 예측합니다"
            android:textColor="#5a7a9a"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="누적 소견"
            android:textColor="#00cfff"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/statText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="#0f1e35"
            android:lineSpacingExtra="4dp"
            android:padding="14dp"
            android:text="분석 대기"
            android:textColor="#ffffff"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="로그"
            android:textColor="#5a7a9a"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="6dp"
            android:background="#132040"
            android:padding="12dp"
            android:textColor="#5a7a9a"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
